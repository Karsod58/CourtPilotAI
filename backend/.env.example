# CourtPilot Configuration
# Copy this file to .env and update with your actual values

# Application
APP_NAME=CourtPilot
APP_VERSION=1.0.0
DEBUG=True
ENVIRONMENT=development

# Server
HOST=0.0.0.0
PORT=8000

# Database - SQLite (Default - Recommended for development)
USE_SQLITE=True
DATABASE_URL=sqlite:///./courtpilot.db

# Database - Direct URL Override (For Render/Railway - they provide DATABASE_URL)
# If DATABASE_URL is set, it will override all other database settings
# DATABASE_URL_OVERRIDE=postgresql://user:pass@host:5432/dbname

# Database - PostgreSQL (For production)
# USE_SQLITE=False
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_DB=courtpilot
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=your_postgres_password_here

# Database - MySQL (Alternative)
# USE_SQLITE=False
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DB=courtpilot
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password_here

# Database - PostgreSQL (Optional - Alternative)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=courtpilot
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_postgres_password_here

# Database - MongoDB (Optional - For document storage)
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB=courtpilot

# Redis (Optional - For caching and Celery)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# AI/LLM Configuration
# Choose provider: "openai", "anthropic", or "ollama"
LLM_PROVIDER=ollama

# Ollama Configuration (Recommended - Free & Open Source)
# Get API key from: https://ollama.com
OLLAMA_BASE_URL=https://ollama.com
OLLAMA_API_KEY=your_ollama_api_key_here
OLLAMA_MODEL=gemma3:12b
# Alternative Ollama models: llama3.1:8b, mistral, mixtral, llama3.1:70b, codellama, phi3

# OpenAI Configuration (Alternative - Paid)
# Get API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here
LLM_MODEL=gpt-4-turbo-preview
EMBEDDING_MODEL=text-embedding-3-small

# Anthropic Configuration (Alternative - Paid)
# Get API key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Vector Store Configuration
VECTOR_STORE_TYPE=faiss  # Options: faiss or chroma
VECTOR_STORE_PATH=./data/vector_store

# OCR Configuration
TESSERACT_PATH=/usr/bin/tesseract  # Windows: C:/Program Files/Tesseract-OCR/tesseract.exe
OCR_LANGUAGE=eng+hin  # English and Hindi

# Document Storage
DOCUMENT_STORAGE_PATH=./data/documents
MAX_UPLOAD_SIZE=52428800  # 50MB in bytes

# Security
SECRET_KEY=your_secret_key_here_change_in_production_use_openssl_rand_hex_32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS (Frontend URLs)
CORS_ORIGINS=["http://localhost:3000", "http://localhost:5173", "http://localhost:5174"]

# Logging
LOG_LEVEL=INFO
LOG_FILE=./logs/courtpilot.log

# Celery (Optional - For background tasks)
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# AI Processing Configuration
CONFIDENCE_THRESHOLD=0.7
LOW_CONFIDENCE_THRESHOLD=0.5
BATCH_SIZE=10

# Alert Configuration (Optional)
ALERT_EMAIL_ENABLED=False
ALERT_SMS_ENABLED=False
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_email_password_here

# Department Mapping
DEPARTMENT_MAPPING_FILE=./data/department_mapping.json

# Legal Intelligence
SIMILAR_CASE_THRESHOLD=0.8
APPEAL_RECOMMENDATION_THRESHOLD=0.6

# RAG System
RAG_CHUNK_SIZE=1000
RAG_CHUNK_OVERLAP=200
RAG_TOP_K=5

# Feature Flags
ENABLE_RAG=True
ENABLE_AUTO_EXTRACT=True
ENABLE_NOTIFICATIONS=False
ENABLE_EMAIL_ALERTS=False
